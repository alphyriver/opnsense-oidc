{
    "name": "alphyriver/opnsense-oidc",
    "description": "Development tooling for the OPNsense OIDC plugin. This file is NOT shipped in the built package (only Makefile, pkg-descr and src/ are packaged).",
    "license": "BSD-2-Clause",
    "type": "project",
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpseclib/phpseclib": "^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "OPNsense\\Oidc\\": "src/opnsense/mvc/app/library/OPNsense/Oidc/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration"
    },
    "config": {
        "sort-packages": true
    }
}
