# OPNsense pkg repository for the os-oidc plugin.
#
# Install on a node as /usr/local/etc/pkg/repos/oidc.conf and place the
# matching public key at /usr/local/etc/pkg/keys/oidc.pub. The release workflow
# renders this template (substituting @PAGES_URL@) and publishes the ready-to-use
# file at @PAGES_URL@/oidc.conf — fetch that rather than editing this by hand.
#
# ${ABI} expands client-side (e.g. FreeBSD:14:amd64), so one conf works across
# FreeBSD/OPNsense ABIs as long as the feed publishes that ABI's directory.
oidc: {
  url: "@PAGES_URL@/${ABI}",
  priority: 10,
  enabled: yes,
  signature_type: "pubkey",
  pubkey: "/usr/local/etc/pkg/keys/oidc.pub"
}
